# Docker testing environment — do not use in production

# Database (matches docker/postgres/init.sh)
DB_NAME=team_manager_db
DB_SCHEMA=team_manager
DB_USER=team_app
DB_PASS=team_app_dev

# Admin credentials
# ADMIN_PASSWORD is used by docker/php/entrypoint.sh to generate ADMIN_PASSWORD_HASH at startup.
# Change ADMIN_PASSWORD to whatever you want — no manual hashing needed.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PASSWORD_HASH=

APP_ENV=development
BASE_URL=localhost:8080
